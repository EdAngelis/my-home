@baseUrl = http://localhost:3000
@dutyId = REPLACE_WITH_A_DUTY_ID
@userId = REPLACE_WITH_A_BUYER_ID
@homeId = REPLACE_WITH_A_HOME_ID

### List duties (home is required; query is passed straight to Mongoose find) — GET /duties
GET {{baseUrl}}/duties?home={{homeId}}
# &createdByUserId={{userId}}
# &category=REPLACE_WITH_A_CATEGORY_ID
# &status=active
# &makers=REPLACE_WITH_A_MAKER_ID

### Create a new duty (home is required) — POST /duties/create
POST {{baseUrl}}/duties/create
Content-Type: application/json

{
  "cod": "clean-kitchen-1717171717171",
  "name": "Clean the kitchen",
  "frequency": 7,
  "value": 1,
  "description": "Wipe counters and sweep the floor",
  "history": [],
  "createdByUserId": "{{userId}}",
  "home": "{{homeId}}",
  "category": "REPLACE_WITH_A_CATEGORY_ID",
  "makers": ["REPLACE_WITH_A_MAKER_ID"],
  "status": "active"
}

### Get a duty by id (home is required and must match the duty's home) — GET /duties/:id
GET {{baseUrl}}/duties/{{dutyId}}?home={{homeId}}

### Update a duty by id (mark done / edit / pause; home is required) — PATCH /duties/:id
PATCH {{baseUrl}}/duties/{{dutyId}}?home={{homeId}}
Content-Type: application/json

{
  "frequency": 14,
  "makers": ["REPLACE_WITH_A_MAKER_ID"],
  "status": "paused",
  "history": [{ "date": "2026-06-30T00:00:00.000Z", "maker": "REPLACE_WITH_A_MAKER_ID" }]
}

### Bulk-update duties matching a query (home is required) — PATCH /duties
PATCH {{baseUrl}}/duties?home={{homeId}}
Content-Type: application/json

{
  "status": "active"
}

### Delete a duty by id (home is required and must match the duty's home) — DELETE /duties/:id
DELETE {{baseUrl}}/duties/{{dutyId}}?home={{homeId}}

### Bulk-delete duties matching a query (home is required) — DELETE /duties
DELETE {{baseUrl}}/duties?home={{homeId}}
