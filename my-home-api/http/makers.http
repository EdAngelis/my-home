@baseUrl = http://localhost:3000
@makerId = REPLACE_WITH_A_MAKER_ID
@userId = REPLACE_WITH_A_BUYER_ID

### List makers (scoped per user via query) — GET /makers
GET {{baseUrl}}/makers?createdByUserId={{userId}}

### Create a new maker — POST /makers/create
POST {{baseUrl}}/makers/create
Content-Type: application/json

{
  "name": "Alice",
  "createdByUserId": "{{userId}}"
}

### Get a maker by id — GET /makers/:id
GET {{baseUrl}}/makers/{{makerId}}

### Update a maker by id — PATCH /makers/:id
PATCH {{baseUrl}}/makers/{{makerId}}
Content-Type: application/json

{
  "name": "Alice B."
}

### Bulk-update makers matching a query — PATCH /makers
PATCH {{baseUrl}}/makers?createdByUserId={{userId}}
Content-Type: application/json

{
  "name": "Renamed"
}

### Delete a maker by id (cascades: pulls it from every duty's makers array) — DELETE /makers/:id
DELETE {{baseUrl}}/makers/{{makerId}}

### Bulk-delete makers matching a query — DELETE /makers
DELETE {{baseUrl}}/makers?createdByUserId={{userId}}
