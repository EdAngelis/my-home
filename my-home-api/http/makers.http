@baseUrl = http://localhost:3000
@makerId = REPLACE_WITH_A_MAKER_ID
@userId = REPLACE_WITH_A_BUYER_ID
@homeId = REPLACE_WITH_A_HOME_ID

### List makers scoped per home
GET {{baseUrl}}/makers?home={{homeId}}

### Create a new maker
POST {{baseUrl}}/makers/create
Content-Type: application/json

{
  "name": "Alice",
  "createdByUserId": "{{userId}}",
  "home": "{{homeId}}"
}

### Get a maker by id
GET {{baseUrl}}/makers/{{makerId}}?home={{homeId}}

### Update a maker by id
PATCH {{baseUrl}}/makers/{{makerId}}?home={{homeId}}
Content-Type: application/json

{
  "name": "Alice B."
}

### Bulk-update makers matching a scoped query
PATCH {{baseUrl}}/makers?home={{homeId}}
Content-Type: application/json

{
  "name": "Renamed"
}

### Delete a maker by id
DELETE {{baseUrl}}/makers/{{makerId}}?home={{homeId}}

### Bulk-delete makers matching a scoped query
DELETE {{baseUrl}}/makers?home={{homeId}}
