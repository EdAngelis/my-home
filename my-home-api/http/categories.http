@baseUrl = http://localhost:3000
@categoryId = REPLACE_WITH_A_CATEGORY_ID
@userId = REPLACE_WITH_A_BUYER_ID
@homeId = REPLACE_WITH_A_HOME_ID

### List categories scoped per home
GET {{baseUrl}}/categories?home={{homeId}}

### Create a new category
POST {{baseUrl}}/categories/create
Content-Type: application/json

{
  "name": "Home",
  "createdByUserId": "{{userId}}",
  "home": "{{homeId}}"
}

### Get a category by id
GET {{baseUrl}}/categories/{{categoryId}}?home={{homeId}}

### Update a category by id
PATCH {{baseUrl}}/categories/{{categoryId}}?home={{homeId}}
Content-Type: application/json

{
  "name": "Household"
}

### Bulk-update categories matching a scoped query
PATCH {{baseUrl}}/categories?home={{homeId}}
Content-Type: application/json

{
  "name": "Renamed"
}

### Delete a category by id
DELETE {{baseUrl}}/categories/{{categoryId}}?home={{homeId}}

### Bulk-delete categories matching a scoped query
DELETE {{baseUrl}}/categories?home={{homeId}}
