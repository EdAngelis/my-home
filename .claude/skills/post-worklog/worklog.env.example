# Copy this file to `worklog.env` (same folder) and fill in the values.
# `worklog.env` is gitignored and is auto-sourced by post-worklog.sh, so you set
# these once instead of exporting env vars in every shell.

# Base URL of the Issues Creator app (no trailing slash).
WORKLOG_API_URL="http://localhost:3000"

# Must equal WORKLOG_API_TOKEN in the app's .env.local.
WORKLOG_API_TOKEN=""
